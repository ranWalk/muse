---
import LanguagePicker from "./LanguagePicker.astro";

const { active = "home", showLanguage = false } = Astro.props;
const isActive = (key) => active === key ? " active" : "";
---
<header class="site-header">
  <a class="brand" href="/" aria-label="aylamuse home">
    <img class="brand-logo" src="/assets/aylamuse-logo.svg" alt="aylamuse" />
  </a>

  <button class="menu-toggle" type="button" data-menu-toggle aria-expanded="false" aria-label="Toggle navigation">
    <span></span>
    <span></span>
  </button>

  <nav class="site-nav" aria-label="Main navigation">
    <a class={`nav-link${isActive("home")}`} href="/" data-i18n="navHome">Home</a>
    <a class={`nav-link${isActive("collections")}`} href="/collections/" data-i18n="navCollections">Shop by Need</a>
    <div class="nav-dropdown">
      <a class={`nav-link nav-trigger${isActive("products")}`} href="/products/" data-i18n="navProducts" aria-expanded="false">Products</a>
      <div class="product-menu" aria-label="Product navigation">
        <a href="/products/#beginners" data-i18n="productNavBeginners">Beginner Kits</a>
        <a href="/products/#solo" data-i18n="productNavSolo">Solo Wellness</a>
        <a href="/products/#couples" data-i18n="productNavCouples">Couples Play</a>
        <a href="/products/#care" data-i18n="productNavCare">Care Essentials</a>
      </div>
    </div>
    <a class={`nav-link${isActive("promise")}`} href="/promise/" data-i18n="navPromise">Our Promise</a>
    <a class={`nav-link${isActive("guides")}`} href="/guides/" data-i18n="navGuides">Guides</a>
    <a class={`nav-link${isActive("contact")}`} href="/contact/" data-i18n="navContact">Contact</a>
  </nav>

  {showLanguage && <LanguagePicker />}
</header>
