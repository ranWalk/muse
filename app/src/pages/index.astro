---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="aylamuse | Intimate Wellness Essentials" bodyClass="home-page" active="home" showLanguage={true}>
  <main class="homepage-artboard" aria-label="AylaMuse visual homepage">
    <section class="art-slice art-hero" id="top" style="--slice-ratio: 1600 / 760;">
      <img class="slice-image" src="/assets/slide-5.svg" alt="" />
      <div class="slice-shade"></div>
      <div class="slice-content hero-layout">
        <div class="hero-brand-block">
          <img src="/assets/aylamuse-logo.svg" alt="aylamuse" />
          <span>Intimate Wellness Co.</span>
        </div>
        <div class="hero-statement">
          <p data-i18n="homeHeroKicker">20+ thoughtful essentials</p>
          <h1 data-i18n="homeHeroTitle">Private care for curious, confident adults</h1>
          <a class="hot-button" href="/collections/" data-i18n="homeHeroCta">View New Arrivals</a>
        </div>
      </div>
      <a class="hotspot hero-hotspot" href="/collections/" aria-label="View featured collections"></a>
    </section>

    <section class="art-slice language-slice" style="--slice-ratio: 1600 / 245;">
      <div class="slice-content centered-copy">
        <p class="micro-title" data-i18n="homeLanguageKicker">Multi-language</p>
        <h2 data-i18n="homeLanguageTitle">Global-friendly shopping, private by default</h2>
        <div class="flag-row" aria-label="Supported languages">
          <span>DE</span><span>PT</span><span>ES</span><span>FR</span><span>IT</span><span>RU</span><span>KO</span><span>JA</span><span>AR</span><span>TH</span><span>VI</span><span>TR</span><span>NL</span><span>ID</span><span>HE</span><span>HI</span><span>EN</span><span>ZH</span>
        </div>
      </div>
    </section>

    <section class="art-slice navigation-slice" style="--slice-ratio: 1600 / 520;">
      <div class="slice-content centered-copy">
        <p class="micro-title" data-i18n="homeNavigationKicker">Classified Navigation</p>
        <h2 data-i18n="homeNavigationTitle">Shop by the kind of support you want</h2>
        <div class="visual-card-grid">
          <a class="visual-card" href="/products/#beginners"><span class="product-line"></span><strong data-i18n="cardBeginnerTitle">Beginner Kits</strong><small data-i18n="cardBeginnerText">Gentle first steps</small></a>
          <a class="visual-card" href="/products/#solo"><span class="product-line thin"></span><strong data-i18n="cardSoloTitle">Solo Wellness</strong><small data-i18n="cardSoloText">Quiet personal rituals</small></a>
          <a class="visual-card" href="/products/#couples"><span class="product-line warm"></span><strong data-i18n="cardCouplesTitle">Couples Play</strong><small data-i18n="cardCouplesText">Shared discovery</small></a>
          <a class="visual-card" href="/products/#care"><span class="product-line compact"></span><strong data-i18n="cardCareTitle">Care Essentials</strong><small data-i18n="cardCareText">Clean, store, reset</small></a>
        </div>
      </div>
    </section>

    <section class="art-slice about-slice" style="--slice-ratio: 1600 / 640;">
      <img class="slice-image muted" src="/assets/slide-3.svg" alt="" />
      <div class="slice-content split-layout">
        <div class="copy-panel light">
          <p class="micro-title" data-i18n="homeAboutKicker">About Us</p>
          <h2 data-i18n="homeAboutTitle">Designed around calm browsing and clear choices</h2>
          <p data-i18n="homeAboutText">AylaMuse keeps the shopping path simple: privacy first, body-safe guidance, beginner-friendly language, and fast access to a private recommendation.</p>
        </div>
        <div class="image-collage">
          <img src="/assets/slide-1.svg" alt="Soft landscape placeholder for brand imagery" />
          <img src="/assets/slide-2.svg" alt="Warm landscape placeholder for lifestyle imagery" />
          <img src="/assets/slide-4.svg" alt="Quiet forest placeholder for care imagery" />
        </div>
      </div>
    </section>

    <section class="art-slice band-slice" style="--slice-ratio: 1600 / 420;">
      <div class="slice-content band-layout">
        <div class="brand-mark">AM</div>
        <div>
          <p class="micro-title" data-i18n="homeBandKicker">AylaMuse Collection</p>
          <h2 data-i18n="homeBandTitle">Soft launch essentials for every comfort level</h2>
          <a class="hot-button" href="/contact/" data-i18n="matchCta">Ask Privately</a>
        </div>
      </div>
    </section>

    <section class="art-slice certificate-slice" style="--slice-ratio: 1600 / 610;">
      <div class="slice-content centered-copy">
        <p class="micro-title" data-i18n="homeCertificateKicker">Certificate Presentation</p>
        <h2 data-i18n="homeCertificateTitle">Trust signals stay visible before product decisions</h2>
        <div class="certificate-row">
          <article></article>
          <article class="front"></article>
          <article></article>
        </div>
      </div>
    </section>

    <section class="art-slice fair-slice" style="--slice-ratio: 1600 / 690;">
      <div class="slice-content centered-copy">
        <p class="micro-title" data-i18n="homeFairKicker">Canton Fair</p>
        <h2 data-i18n="homeFairTitle">Launch-ready visual stories</h2>
        <div class="fair-board">
          <div></div><div></div><div></div><div></div><div></div><div></div>
        </div>
      </div>
    </section>

    <section class="art-slice service-slice" style="--slice-ratio: 1600 / 290;">
      <div class="slice-content service-grid">
        <a href="/contact/"><strong data-i18n="serviceAdviceTitle">Product Advice</strong><span data-i18n="serviceAdviceText">Private recommendations</span></a>
        <a href="/promise/"><strong data-i18n="serviceMaterialTitle">Material Focus</strong><span data-i18n="serviceMaterialText">Plain-language care guidance</span></a>
        <a href="/collections/"><strong data-i18n="serviceAccessTitle">Easy Access</strong><span data-i18n="serviceAccessText">Need-based navigation</span></a>
      </div>
    </section>

    <section class="art-slice best-seller-slice" id="collections" style="--slice-ratio: 1600 / 1040;">
      <div class="slice-content centered-copy">
        <p class="micro-title" data-i18n="homeBestKicker">Best Sellers</p>
        <h2 data-i18n="homeBestTitle">Popular directions to explore</h2>
        <div class="seller-grid">
          <a class="seller-card" href="/products/#beginners"><span class="product-line"></span><strong data-i18n="cardFirstDiscovery">First-Time Discovery</strong><small>$5.00 - $8.00</small></a>
          <a class="seller-card" href="/products/#solo"><span class="product-line thin"></span><strong data-i18n="cardPersonalPleasure">Personal Pleasure</strong><small>$5.00 - $8.00</small></a>
          <a class="seller-card" href="/products/#couples"><span class="product-line warm"></span><strong data-i18n="cardCouplesConnection">Couples & Connection</strong><small>$5.00 - $8.00</small></a>
          <a class="seller-card" href="/products/#care"><span class="product-line compact"></span><strong data-i18n="cardCareAccessories">Care & Accessories</strong><small>$5.00 - $8.00</small></a>
          <a class="seller-card" href="/contact/"><span class="product-line spring"></span><strong data-i18n="cardQuietCare">Quiet Care Set</strong><small>$5.00 - $8.00</small></a>
          <a class="seller-card" href="/contact/"><span class="product-line minimal"></span><strong data-i18n="cardPrivateStarter">Private Starter Pack</strong><small>$5.00 - $8.00</small></a>
        </div>
      </div>
    </section>

    <section class="art-slice product-feature front-feature" style="--slice-ratio: 1600 / 520;">
      <div class="slice-content product-feature-layout">
        <span class="large-product"></span>
        <div>
          <p class="micro-title" data-i18n="homeFrontKicker">Front Care Essential</p>
          <h2 data-i18n="homeFrontTitle">Supportive picks for first-time shoppers</h2>
          <a class="hot-button" href="/contact/" data-i18n="collectionCta">Get Recommendation</a>
        </div>
      </div>
    </section>

    <section class="art-slice mosaic-slice" style="--slice-ratio: 1600 / 520;">
      <div class="slice-content mosaic-grid">
        <a href="/contact/">New Look</a>
        <span class="product-line"></span>
        <span class="product-line thin"></span>
        <span class="product-line warm"></span>
        <span class="product-line compact"></span>
        <span class="product-line spring"></span>
        <span class="product-line minimal"></span>
      </div>
    </section>

    <section class="art-slice product-feature rear-feature" style="--slice-ratio: 1600 / 520;">
      <div class="slice-content product-feature-layout reverse">
        <span class="large-product spring"></span>
        <div>
          <p class="micro-title" data-i18n="homeRearKicker">Care Routine</p>
          <h2 data-i18n="homeRearTitle">Simple aftercare, storage, and cleaning support</h2>
          <a class="hot-button" href="/contact/" data-i18n="ctaButton">Contact Us</a>
        </div>
      </div>
    </section>

    <section class="art-slice footer-slice" style="--slice-ratio: 1600 / 360;">
      <div class="slice-content footer-layout">
        <div>
          <img src="/assets/aylamuse-logo.svg" alt="aylamuse" />
          <p>Where private wellness begins.</p>
        </div>
        <div>
          <strong data-i18n="homeContactWay">Contact Way</strong>
          <a href="/contact/" data-i18n="homePrivateMessage">Private message</a>
          <a href="#top" data-i18n="homeBackTop">Back to top</a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
