---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="aylamuse | Our Promise" active="promise">
  <main class="page-shell">
    <section class="page-hero">
      <div>
        <p class="eyebrow" data-i18n="promisePageKicker">Our Promise</p>
        <h1 data-i18n="promisePageTitle">Privacy, clarity, and calm support.</h1>
        <p data-i18n="promisePageText">AylaMuse is shaped around respectful adult wellness: discreet packaging expectations, clear product language, and beginner-friendly support.</p>
      </div>
      <div class="page-visual" aria-hidden="true"></div>
    </section>
    <section class="page-section">
      <ul class="page-list">
        <li data-i18n="promisePrivacy"><strong>Privacy first.</strong> Browsing, messaging, and packaging language stays discreet.</li>
        <li data-i18n="promiseMaterial"><strong>Material clarity.</strong> Product copy should make materials, cleaning, and usage easy to understand.</li>
        <li data-i18n="promiseGuidance"><strong>Gentle guidance.</strong> Recommendations begin with comfort level and boundaries.</li>
      </ul>
    </section>
  </main>
</BaseLayout>
