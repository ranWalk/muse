---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="aylamuse | Private Contact" active="contact" showLanguage={true}>
  <main class="contact-layout">
    <section class="contact-card">
      <p class="eyebrow" data-i18n="contactEyebrow">Private Support</p>
      <h1 data-i18n="contactTitle">Ask privately</h1>
      <p class="contact-intro" data-i18n="contactIntro">If you are not sure what fits your needs, describe your comfort level, experience, and shopping goal. This demo stores messages in your browser only.</p>

      <div class="contact-list">
        <div class="contact-item">
          <span class="contact-label" data-i18n="contactGoodForLabel">Good for</span>
          <strong data-i18n="contactGoodFor">First-time shopping, couples, care routines, discreet delivery</strong>
        </div>
        <div class="contact-item">
          <span class="contact-label" data-i18n="contactNoShareLabel">You do not need to share</span>
          <strong data-i18n="contactNoShare">Real name, phone number, address, or sensitive identity details</strong>
        </div>
        <div class="contact-item">
          <span class="contact-label" data-i18n="contactHelpfulLabel">Helpful details</span>
          <strong data-i18n="contactHelpful">Experience level, budget, preferred intensity, solo or shared use</strong>
        </div>
      </div>
    </section>

    <section class="message-board-section">
      <div class="message-board-header">
        <p class="eyebrow" data-i18n="messageEyebrow">Message</p>
        <h2 data-i18n="messageTitle">Leave a private note</h2>
        <p data-i18n="messageIntro">You can use a nickname. Submitted notes stay visible in this browser after refresh.</p>
      </div>

      <form class="message-form" data-message-form>
        <label>
          <span data-i18n="fieldName">Nickname</span>
          <input type="text" name="name" maxlength="20" placeholder="e.g. Luna, Private shopper" data-i18n-placeholder="fieldNamePlaceholder" required />
        </label>
        <label>
          <span data-i18n="fieldContact">Optional contact</span>
          <input type="text" name="contact" maxlength="60" placeholder="Optional email or preferred contact note" data-i18n-placeholder="fieldContactPlaceholder" />
        </label>
        <label>
          <span data-i18n="fieldMessage">Your question</span>
          <textarea name="message" rows="6" maxlength="260" placeholder="Example: I am new and want something quiet, gentle, and easy to clean for solo use." data-i18n-placeholder="fieldMessagePlaceholder" required></textarea>
        </label>
        <button class="button primary" type="submit" data-i18n="fieldSubmit">Send Message</button>
      </form>

      <div class="message-board" data-message-board>
        <article class="message-empty">
          <h3 data-i18n="emptyTitle">No messages yet</h3>
          <p data-i18n="emptyText">Submit the form above and your private note will appear here.</p>
        </article>
      </div>
    </section>
  </main>
</BaseLayout>
